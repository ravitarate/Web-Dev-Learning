@{
    ViewData["Title"] = "Home Page";
}

<!-- Google Fonts for Marathi (Mukta) and beautiful English text -->
<link href="https://fonts.googleapis.com/css2?family=Mukta:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
    .marathi-font {
        font-family: 'Mukta', sans-serif;
    }
    
    .hero-section {
        min-height: 90vh;
        background: linear-gradient(135deg, rgba(254,250,224,0.85) 0%, rgba(212,163,115,0.85) 100%);
    }

    .hero-section::before {
        background-image: url('https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=2089&auto=format&fit=crop');
        opacity: 0.15;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 20px;
        padding: 3rem;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }
</style>

<div class="hero-section text-center d-flex align-items-center">
    <div class="container position-relative" style="z-index: 2;">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-card animate-up">
                    <h2 class="marathi-font fw-bold" style="color: #bc8e61; font-size: 1.5rem; letter-spacing: 2px;">॥ श्री गणेशाय नमः ॥</h2>
                    <h1 class="hero-title fw-bold mt-3 mb-4" style="color: #4a2511; font-size: 3.5rem;">श्री गणेश बेकरी <br><span class="marathi-font fs-3 text-secondary">पुण्याची अस्सल चव</span></h1>
                    
                    <p class="marathi-font text-dark fw-medium fs-5 mb-4 lh-lg">
                        पुण्याच्या जुन्या आठवणींना उजाळा देणारी आमची बेकरी. <br>
                        गरमागरम पफ, चहासोबतची लाडकी खारी, आणि जिभेवर रेंगाळणारी बिस्कीटे. <br>
                        <strong>तुमच्या रोजच्या दिवसाची गोड सुरुवात!</strong>
                    </p>
                    
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-controller="Menu" asp-action="Index" class="marathi-font btn btn-primary-custom btn-lg shadow-sm px-5 fs-5">
                            आमचा मेनू पहा (Menu)
                        </a>
                        <a href="#about" class="marathi-font btn btn-outline-dark btn-lg shadow-sm rounded-pill px-4 fs-5 fw-semibold border-2 bg-white bg-opacity-75">
                            आमची ओळख
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 my-5" id="about">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
            <h2 class="mb-4 text-dark display-5 marathi-font fw-bold" style="color: #4a2511 !important;">पुण्याचा स्वाद, प्रत्येक घासात!</h2>
            <p class="lead text-muted mb-4 marathi-font lh-lg fs-5">
                पुण्याच्या ऐतिहासिक रस्त्यांवर वसलेली <strong>श्री गणेश बेकरी</strong> गेली अनेक वर्षे अस्सल चव जपत आहे. 
                सकाळच्या चहासोबत खारी असो वा संध्याकाळच्या भुकेसाठी गरमागरम पफ, पुण्याच्या प्रत्येक घरात आमची ओळख आहे.
            </p>
            <ul class="list-unstyled mb-4 marathi-font fs-5">
                <li class="mb-3 d-flex align-items-center text-secondary">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa-solid fa-fire-burner text-primary fs-4"></i>
                    </div>
                    <span>रोज सकाळी ताजी बेकिंग (Baked Fresh Daily)</span>
                </li>
                <li class="mb-3 d-flex align-items-center text-secondary">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa-solid fa-leaf text-success fs-4"></i>
                    </div>
                    <span>१००% शुद्ध शाकाहारी (100% Veg)</span>
                </li>
                <li class="mb-3 d-flex align-items-center text-secondary">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa-solid fa-star text-warning fs-4"></i>
                    </div>
                    <span>अस्सल पुणेरी रेसिपी (Authentic Recipe)</span>
                </li>
            </ul>
        </div>
        <div class="col-lg-6">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1549931319-a545dcf3bc73?q=80&w=2670&auto=format&fit=crop" class="img-fluid rounded-4 shadow-lg" alt="Bakery interior" style="border: 8px solid white;" />
                <div class="position-absolute bottom-0 start-0 translate-middle p-4 bg-white rounded-4 shadow-lg" style="margin-left: 20%; margin-bottom: -10%; border-left: 5px solid var(--primary-color);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="fs-1 text-danger">
                            <i class="fa-solid fa-heart"></i>
                        </div>
                        <div class="marathi-font">
                            <h4 class="mb-0 fw-bold">पुणेकरांची लाडकी बेकरी</h4>
                            <small class="text-muted fs-6">गेली १०० वर्षे सेवेत!</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
