@model IEnumerable<BakeryWeb.Models.Product>

@{
    ViewData["Title"] = "आमचा मेनू (Our Menu)";
}

<!-- Google Fonts for Marathi (Mukta) -->
<link href="https://fonts.googleapis.com/css2?family=Mukta:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
    .marathi-font {
        font-family: 'Mukta', sans-serif;
    }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-3 marathi-font" style="color: #4a2511;">थेट ओव्हनमधून...</h1>
        <p class="lead text-muted mx-auto marathi-font fs-5" style="max-width: 600px;">
            पुण्याच्या अस्सल चवीचे आमचे ताजे आणि कुरकुरीत बेकरी पदार्थ. आताच ऑर्डर करा!
        </p>
    </div>

    <!-- Category Filter Buttons -->
    <div class="d-flex justify-content-center gap-3 mb-5 flex-wrap marathi-font fs-5">
        <button class="btn btn-dark rounded-pill px-4 shadow-sm">सर्व (All)</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4 shadow-sm">चटपटीत (Savory snacks)</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4 shadow-sm">बिस्कीटे (Biscuits & Cookies)</button>
        <button class="btn btn-outline-secondary bg-white rounded-pill px-4 shadow-sm">केक्स (Cakes)</button>
    </div>

    <div class="menu-grid">
        @foreach (var product in Model)
        {
            <div class="product-card">
                <div class="product-img-wrapper">
                    <span class="badge-category marathi-font">@product.Category?.Name</span>
                    <img src="@product.ImageUrl" alt="@product.Name" class="product-img" onerror="this.src='https://plus.unsplash.com/premium_photo-1675782713735-e105e46efbb4?q=80&w=1470&auto=format&fit=crop'" />
                </div>
                <div class="product-info d-flex flex-column h-100">
                    <div class="flex-grow-1">
                        <h3 class="product-title fw-bold marathi-font" style="color: #4a2511;">@product.Name</h3>
                        <p class="product-desc marathi-font fs-6 text-muted">@product.Description</p>
                    </div>
                    <div class="product-footer mt-3">
                        <span class="product-price text-success fw-bold fs-4">₹@product.Price.ToString("0.00")</span>
                        <a href="https://wa.me/919876543210?text=Hello,%20I%20would%20like%20to%20order%20@Uri.EscapeDataString(product.Name)" target="_blank" class="marathi-font btn btn-success rounded-pill px-4 shadow-sm text-white fw-bold">
                            <i class="fa-brands fa-whatsapp me-1"></i> ऑर्डर द्या
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
